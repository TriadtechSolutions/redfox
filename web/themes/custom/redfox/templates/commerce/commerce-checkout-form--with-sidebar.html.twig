{#
/**
 * @file
 * Two column template for the checkout form.
 *
 * Available variables:
 * - form: The form.
 *
 * @ingroup themeable
 */
#}
<div class="layout-checkout-form">
	<div class="row justify-content-center">
		<div class="col-md-10 col-lg-8">
			{{ form|without('sidebar', 'actions') }}

			<div class="checkout-summary-wrapper mt-4">
				<h3 class="mb-4">{% trans %}
					Order Summary
					{% endtrans %}</h3>
				{{ form.sidebar }}
			</div>

			<div class="layout-region-checkout-footer mt-4">
				{{ form.actions }}
			</div>
		</div>
	</div>
</div>
