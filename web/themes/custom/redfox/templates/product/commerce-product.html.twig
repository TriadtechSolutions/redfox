{#
/**
 * @file
 * Default theme implementation to display a product.
 *
 * Available variables:
 * - product: The product entity with all its fields.
 * - product_url: The URL of the product.
 */
#}

{{ attach_library('redfox/product-zoom') }}

<article{{attributes.addClass('product-detail')}}>

	<div
		class="product-container">

		{# Product Gallery Section #}
		<div class="product-gallery">
			{% if product.variation_field_product_image %}
				<div
					class="product-images-wrapper">
					{# Main Image Display #}
					<div class="main-image-container">
						{{ product.variation_field_product_image }}
					</div>

					{# Thumbnail Gallery #}
					<div class="thumbnail-gallery">
						{{ product.variation_field_product_image }}
					</div>
				</div>
			{% endif %}

			{# Brand Logo #}
			{% if product.variation_field_brand_logo or product.variation_field_brands %}
				<div class="product-brand">
					{% if product.variation_field_brand_logo %}
						{{ product.variation_field_brand_logo }}
					{% endif %}
					{% if product.variation_field_brands %}
						{{ product.variation_field_brands }}
					{% endif %}
				</div>
			{% endif %}
		</div>

		{# Product Information Section #}
		<div
			class="product-info">

			{# SKU #}
			{% if product.variation_sku %}
				<div class="product-sku">
					<span class="sku-label">MODEL:</span>
					<span class="sku-value">{{ product.variation_sku }}</span>
				</div>
			{% endif %}

			{# Product Title #}
			{% if product.variation_title %}
				<h1 class="product-title">
					{{ product.variation_title }}
				</h1>
			{% endif %}

			{# Price & Stock #}
			{% if product.variation_price %}
				<div class="price-stock-wrapper">
					<div class="product-price">
						{{ product.variation_price }}
						{% if product.variation_list_price %}
							<span class="product-list-price">{{ product.variation_list_price }}</span>
						{% endif %}
					</div>
					<div class="stock-status in-stock">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
						In Stock - Ships Tomorrow
					</div>
				</div>
			{% endif %}

			{% if product.variations %}
				<div class="product-purchase">
					{{ product.variations }}
				</div>
			{% endif %}

			{# Trust Icons #}
			<div class="trust-icons">
				<div class="trust-item">
					<div class="trust-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
					</div>
					<div class="trust-label">3 Year Warranty</div>
				</div>
				<div class="trust-item">
					<div class="trust-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-5l-4-4h-3v10a1 1 0 0 0 1 1Z"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
					</div>
					<div class="trust-label">Free Shipping</div>
				</div>
				<div class="trust-item">
					<div class="trust-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
					</div>
					<div class="trust-label">30-Day Returns</div>
				</div>
			</div>

			{# Specifications Table #}
			<div class="product-specifications">
				<h2 class="specifications-title">Specifications</h2>
				<table class="specifications-table">
					<tbody>
						{% set excluded_fields = [
							'variation_field_product_image',
							'variation_field_product_images',
							'variation_field_brand_logo',
							'variation_field_brands',
							'variation_field_category',
							'variation_field_tool_type',
							'variation_field_description'
						] %}

						{% for key, field in product %}
							{% if key starts with 'variation_field_' and key not in excluded_fields %}
								{% set is_boolean = field['#field_type'] == 'boolean' %}
								{% set show_field = false %}

								{% if is_boolean %}
									{% if field['#items'].0.value == 1 %}
										{% set show_field = true %}
									{% endif %}
								{% elseif field|render|striptags|trim %}
									{% set show_field = true %}
								{% endif %}

								{% if show_field %}
									<tr>
										<th>{{ field['#title']|default(key|replace({'variation_field_': ''})|replace({'_': ' '})|title) }}</th>
										<td>{{ field }}</td>
									</tr>
								{% endif %}
							{% endif %}
						{% endfor %}
					</tbody>
				</table>
			</div>
			{% if product.variation_field_description %}
				<h2 class="description-title">
					Product Description</h2>
				<div class="product-description">
					{{ product.variation_field_description }}
				</div>
			{% endif %}

			{# Why Shop With Us #}
			<div class="why-shop-us">
				<h3 class="why-title">Why Shop with Redfox?</h3>
				<div class="why-grid">
					<div class="why-item">
						<h4>Quality Assurance</h4>
						<p>Every tool is rigorously tested to meet industrial standards.</p>
					</div>
					<div class="why-item">
						<h4>Transparent Pricing</h4>
						<p>No hidden costs. Get the best value for your industrial needs.</p>
					</div>
					<div class="why-item">
						<h4>Nationwide Support</h4>
						<p>Our service centers are available across the country.</p>
					</div>
				</div>
			</div>
		</div>

	</div>
</article>
