<?php

/**
 * @file
 * Redfox Commerce module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\commerce_order\Entity\OrderItemInterface;
use Drupal\Core\Url;

/**
 * Implements hook_form_alter().
 */
function redfox_commerce_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (strpos($form_id, 'commerce_order_item_add_to_cart_form') === FALSE) {
    return;
  }

  $request = \Drupal::request();
  $variation_id = $request->query->get('v');

  if (!$variation_id || !is_numeric($variation_id)) {
    return;
  }

  // Store in form state (more reliable than session across submit handlers).
  $form_state->set('redfox_variation_id', (int) $variation_id);

  // Also keep session as fallback for presave.
  $request->getSession()->set('redfox_variation_id', (int) $variation_id);

  // Must run BEFORE Commerce's own submit handler.
  array_unshift($form['#submit'], 'redfox_commerce_add_to_cart_submit');

  // Override the commerce_buy_now button submit handler if it exists.
  if (isset($form['actions']['commerce_buy_now'])) {
    $form['actions']['commerce_buy_now']['#submit'] = ['redfox_commerce_buy_now_submit'];
  }
}

/**
 * Submit handler - runs before Commerce's addOrderItem().
 */
function redfox_commerce_add_to_cart_submit($form, FormStateInterface &$form_state) {
  $variation_id = $form_state->get('redfox_variation_id');

  if (!$variation_id) {
    return;
  }

  /** @var \Drupal\commerce_product\Entity\ProductVariationInterface $variation */
  $variation = \Drupal::entityTypeManager()
    ->getStorage('commerce_product_variation')
    ->load($variation_id);

  if (!$variation) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  /** @var \Drupal\commerce_order\Entity\OrderItemInterface $order_item */
  $order_item = $form_object->getEntity();
  if (!$order_item) {
    return;
  }

  // Set correct variation on the order item entity in memory.
  $order_item->set('purchased_entity', $variation);
  $order_item->set('unit_price', $variation->getPrice());

  // -----------------------------------------------------------------------
  // CRITICAL: Commerce's AddToCartForm::submitForm() calls
  // $this->entity = $this->buildEntity($form, $form_state) which will
  // REBUILD the entity from form values — overwriting what we just set.
  // We must also override the 'purchased_entity' in the form field values
  // so buildEntity() picks up our variation.
  // -----------------------------------------------------------------------

  // Override the selected variation in form state values so buildEntity()
  // uses our variation when it reconstructs the order item.
  $form_state->setValue(['purchased_entity', 0, 'variation'], $variation_id);

  // Some Commerce versions store it differently — cover both:
  if ($form_state->hasValue('purchased_entity')) {
    $purchased = $form_state->getValue('purchased_entity');
    if (is_array($purchased)) {
      $purchased[0]['variation'] = $variation_id;
      $form_state->setValue('purchased_entity', $purchased);
    }
  }
}

/**
 * Implements hook_ENTITY_TYPE_presave() for commerce_order_item.
 *
 * Last line of defense — if buildEntity() still got the wrong variation,
 * correct it before the DB write.
 */
function redfox_commerce_commerce_order_item_presave(OrderItemInterface $order_item) {
  $session = \Drupal::request()->getSession();
  $variation_id = $session->get('redfox_variation_id');

  if (!$variation_id) {
    return;
  }

  $variation = \Drupal::entityTypeManager()
    ->getStorage('commerce_product_variation')
    ->load($variation_id);

  if (!$variation) {
    $session->remove('redfox_variation_id');
    return;
  }

  $current = $order_item->getPurchasedEntity();
  if ($current && $current->getProductId() == $variation->getProductId()) {
    $order_item->set('purchased_entity', $variation);
    $order_item->set('unit_price', $variation->getPrice());
  }

  $session->remove('redfox_variation_id');
}

/**
 * Custom submit handler for Buy Now button from commerce_buy_now module.
 */
function redfox_commerce_buy_now_submit($form, FormStateInterface $form_state) {
  $form_storage = $form_state->getStorage();
  $product = $form_storage['product'];

  // Try to get the selected variation from the form object if possible,
  // otherwise fallback to the first variation.
  $variation_obj = NULL;
  $form_object = $form_state->getFormObject();
  if (method_exists($form_object, 'getEntity')) {
    $order_item = $form_object->getEntity();
    if ($order_item && method_exists($order_item, 'getPurchasedEntity')) {
      $variation_obj = $order_item->getPurchasedEntity();
    }
  }

  $entity_type_manager = \Drupal::entityTypeManager();
  if (!$variation_obj) {
    $product_variation_id = $product->get('variations')->target_id;
    $variation_obj = $entity_type_manager
      ->getStorage('commerce_product_variation')
      ->load($product_variation_id);
  }

  $store_id = $product->get('stores')->target_id;
  $store = $entity_type_manager
    ->getStorage('commerce_store')
    ->load($store_id);

  // Instead of using the default cart (which merges with previous items),
  // we use a separate order for "Buy Now".
  $session = \Drupal::request()->getSession();
  $buy_now_order_id = $session->get('commerce_buy_now_order_id');
  $order_storage = $entity_type_manager->getStorage('commerce_order');
  $buy_now_order = NULL;

  if ($buy_now_order_id) {
    $buy_now_order = $order_storage->load($buy_now_order_id);
    // Ensure it's still a draft and for the correct store.
    if (!$buy_now_order || $buy_now_order->getState()->getId() != 'draft' || $buy_now_order->getStoreId() != $store->id()) {
      $buy_now_order = NULL;
      $session->remove('commerce_buy_now_order_id');
    }
  }

  // Load the active payment gateway (Razorpay) so it's set on the order.
  // Without this, PaymentProcess->createPayment() gets a null gateway plugin
  // and crashes with "Call to a member function getPluginId() on null".
  $payment_gateway_storage = $entity_type_manager->getStorage('commerce_payment_gateway');
  $payment_gateway = $payment_gateway_storage->load('razorpay');

  if (!$buy_now_order) {
    $buy_now_order = $order_storage->create([
      'type' => 'default',
      'state' => 'draft',
      'mail' => \Drupal::currentUser()->getEmail(),
      'uid' => \Drupal::currentUser()->id(),
      'store_id' => $store->id(),
      'payment_gateway' => $payment_gateway ? $payment_gateway->id() : NULL,
      'data' => [
        'is_buy_now' => TRUE,
      ],
    ]);
    $buy_now_order->save();
    $session->set('commerce_buy_now_order_id', $buy_now_order->id());
  }
  elseif ($payment_gateway && $buy_now_order->get('payment_gateway')->isEmpty()) {
    // Ensure existing re-used orders also have the gateway set.
    $buy_now_order->set('payment_gateway', $payment_gateway->id());
  }

  // Clear any existing items in the Buy Now order to ensure "only this product".
  foreach ($buy_now_order->getItems() as $item) {
    $buy_now_order->removeItem($item);
    $item->delete();
  }

  $user_input = $form_state->getUserInput();
  $quantity = isset($user_input['quantity'][0]['value']) && $user_input['quantity'][0]['value'] > 0
    ? $user_input['quantity'][0]['value']
    : '1';

  // Add the new item to the order using cart_manager (handles type resolution internally).
  $cart_manager = \Drupal::service('commerce_cart.cart_manager');
  $cart_manager->addEntity($buy_now_order, $variation_obj, $quantity);
  // Suppress the "added to your cart" notification for Buy Now flow.
  \Drupal::messenger()->deleteByType('status');

  // Redirect to the checkout form for this specific order.
  $form_state->setRedirect('commerce_checkout.form', [
    'commerce_order' => $buy_now_order->id(),
  ]);
}